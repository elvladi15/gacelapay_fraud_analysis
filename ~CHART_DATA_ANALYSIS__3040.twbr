      <column caption='TRANSACTION_DATE_MONTH_BUCKETS' datatype='string' name='[Calculation_0365929294675968]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([DATE]) IN(1, 11, 12) THEN &apos;HIGH_RISK_MONTH&apos;&#13;&#10;ELSE &quot;OTHER_MONTHS&quot;&#13;&#10;END' />
      </column>
      <column caption='MERCHANT_CATEGORY_BUCKETS' datatype='string' name='[Calculation_0365929296949250]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT [MERCHANT_CATEGORY] IN(&apos;HIGH VALUE RETAIL&apos;, &apos;TRAVEL&apos;, &apos;GROCERIES&apos;, &apos;DIGITAL GOODS&apos;)&#13;&#10;THEN &apos;OTHER MERCHANT CATEGORIES&apos;&#13;&#10;ELSE [MERCHANT_CATEGORY]&#13;&#10;END' />
      </column>
      <column caption='GROUPED_TIME' datatype='string' name='[Calculation_1308700351098880]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, [TIME]) &lt; 6 THEN &apos;OVERNIGHT (12AM-5AM)&apos;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [TIME]) &lt;= 11 THEN &apos;MORNING (6AM-11AM)&apos;&#13;&#10;ELSEIF DATEPART(&apos;hour&apos;, [TIME]) &lt;= 17 THEN &apos;AFTERNOON (12PM-5PM)&apos;&#13;&#10;ELSE &apos;EVENING (6PM-11PM)&apos;&#13;&#10;END' />
      </column>
